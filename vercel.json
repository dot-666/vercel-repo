{
  "version": 2,
  "routes": [
    {
      "src": "/api/repo",
      "dest": "/api/repo.js"
    }
  ],
  "functions": {
    "api/repo.js": {
      "memory": 512,
      "maxDuration": 30
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ]
}
